{
  "mcpServers": {
    "crm": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-crm"
      ],
      "env": {
        "CRM_API_KEY": "${CRM_API_KEY}"
      }
    },
    "slack": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-slack"
      ],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}"
      }
    }
  }
}