{
  "mcpServers": {
    "notion": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/mcp-server-notion"
      ],
      "env": {
        "NOTION_API_KEY": "${NOTION_API_KEY}"
      }
    },
    "clickup": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-clickup"
      ],
      "env": {
        "CLICKUP_API_KEY": "${CLICKUP_API_KEY}"
      }
    },
    "slack": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-slack"
      ],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}"
      }
    }
  }
}