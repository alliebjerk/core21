{
  "mcpServers": {
    "buffer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-buffer"
      ],
      "env": {
        "BUFFER_ACCESS_TOKEN": "${BUFFER_ACCESS_TOKEN}"
      }
    },
    "meta-business": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-meta-business"
      ],
      "env": {
        "META_ACCESS_TOKEN": "${META_ACCESS_TOKEN}"
      }
    },
    "linkedin": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-linkedin"
      ],
      "env": {
        "LINKEDIN_ACCESS_TOKEN": "${LINKEDIN_ACCESS_TOKEN}"
      }
    }
  }
}