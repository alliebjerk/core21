{
  "mcpServers": {
    "quickbooks": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-quickbooks"
      ],
      "env": {
        "QB_CLIENT_ID": "${QB_CLIENT_ID}",
        "QB_CLIENT_SECRET": "${QB_CLIENT_SECRET}"
      }
    },
    "google-sheets": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-google-sheets"
      ],
      "env": {
        "GSHEETS_CLIENT_ID": "${GMAIL_CLIENT_ID}",
        "GSHEETS_CLIENT_SECRET": "${GMAIL_CLIENT_SECRET}"
      }
    }
  }
}