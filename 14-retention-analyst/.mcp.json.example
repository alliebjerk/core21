{
  "mcpServers": {
    "crm": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-crm"
      ],
      "env": {
        "CRM_API_KEY": "${CRM_API_KEY}"
      }
    },
    "stripe": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-stripe"
      ],
      "env": {
        "STRIPE_API_KEY": "${STRIPE_API_KEY}"
      }
    },
    "google-analytics": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-google-analytics"
      ],
      "env": {
        "GA_CLIENT_ID": "${GMAIL_CLIENT_ID}",
        "GA_CLIENT_SECRET": "${GMAIL_CLIENT_SECRET}"
      }
    }
  }
}